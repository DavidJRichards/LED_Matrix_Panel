; pulse_generator.pio

.program pulse_generator
.side_set 1 opt

.wrap_target
    pull block  side 0   ; 1 cycle
    
    ; Stream 27 individual bits (25 target bits + 2 calibration padding bits = 200ns)
    out pins, 1 side 1
    out pins, 1
    out pins, 1
    out pins, 1
    out pins, 1
    out pins, 1
    out pins, 1
    out pins, 1
    out pins, 1
    out pins, 1
    out pins, 1
    out pins, 1
    out pins, 1
    out pins, 1
    out pins, 1
    out pins, 1
    out pins, 1
    out pins, 1
    out pins, 1
    out pins, 1
    out pins, 1
    out pins, 1
    out pins, 1
    out pins, 1
    out pins, 1
    out pins, 1          ; Calibration padding bit 1 (+8ns)
    out pins, 1          ; Calibration padding bit 2 (+8ns)

    irq wait 0  side 0   ; Total execution window now locked onto exactly 200ns
.wrap
